{
  "name": "mcp-eavesdrop",
  "displayName": "MCP Eavesdrop - Agent MCP Call Monitor",
  "description": "Monitor MCP tool calls from AI agents in real time",
  "version": "0.1.1",
  "license": "MIT",
  "publisher": "industrial-curiosity",
  "icon": "assets/mcp-eavesdrop-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/industrial-curiosity/mcp-eavesdrop.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcpEavesdrop.openPanel",
        "title": "MCP Eavesdrop: Open Agent Monitor Panel"
      },
      {
        "command": "mcpEavesdrop.clearSession",
        "title": "MCP Eavesdrop: Clear Session"
      },
      {
        "command": "mcpEavesdrop.restartDaemon",
        "title": "MCP Eavesdrop: Restart Daemon"
      },
      {
        "command": "mcpEavesdrop.showMcpConfig",
        "title": "MCP Eavesdrop: Show Proxy MCP Config"
      },
      {
        "command": "mcpEavesdrop.enableMonitoring",
        "title": "MCP Eavesdrop: Enable MCP Monitoring"
      },
      {
        "command": "mcpEavesdrop.disableMonitoring",
        "title": "MCP Eavesdrop: Disable MCP Monitoring"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "vscode:prepublish": "node build.mjs",
    "vscode:uninstall": "node ./dist/lifecycle.js",
    "package": "vsce package",
    "sync-skills": "node scripts/sync-skills.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
